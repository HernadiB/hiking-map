  <metadata>
    <name>Csúcsduplázás a Hármashatár-hegy körül</name>
    <author>
      <name>Dömsödi Áron - Magyar Természetjáró Szövetség</name>
    </author>
    <link href="https://www.outdooractive.com/r/29850248"/>
