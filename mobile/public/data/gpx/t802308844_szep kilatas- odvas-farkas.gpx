  <metadata>
    <name>Szép kilátás: Odvas-Farkas kör Budaörs felett</name>
    <author>
      <name>Tenczer Gábor - Magyar Természetjáró Szövetség</name>
    </author>
    <link href="https://www.outdooractive.com/r/802308844"/>
