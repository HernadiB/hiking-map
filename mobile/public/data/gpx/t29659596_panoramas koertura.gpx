  <metadata>
    <name>Panorámás körtúra Alsópetényből</name>
    <author>
      <name>Szabó Eszter - Magyar Természetjáró Szövetség</name>
    </author>
    <link href="https://www.outdooractive.com/r/29659596"/>
    <time>2025-12-27T17:57:57.273Z</time>
