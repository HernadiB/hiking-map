  <metadata>
    <name>Keresztül az esztergomi Vaskapun</name>
    <author>
      <name>Dömsödi Áron - Magyar Természetjáró Szövetség</name>
    </author>
    <link href="https://www.outdooractive.com/r/29183865"/>
