  <metadata>
    <name>A börzsönyi vadon északi kapujában</name>
    <author>
      <name>Német-Bucsi Attila - Magyar Természetjáró Szövetség</name>
    </author>
    <link href="https://www.outdooractive.com/r/28281859"/>
    <time>2025-10-15T12:06:43.126Z</time>
