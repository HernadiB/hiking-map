  <metadata>
    <name>Szép kilátás: Nem füstöl a Pilis kéménye</name>
    <author>
      <name>Tenczer Gábor - Magyar Természetjáró Szövetség</name>
    </author>
    <link href="https://www.outdooractive.com/r/43185464"/>
